# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Monorepo: api/ (Next.js parser SIGFE) + ui/ (Vite + React + Supabase)

# Dependencies (cualquier nivel)
**/node_modules
**/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
**/.next/
**/out/
**/dist/
**/build/

# Testing / coverage
**/coverage/

# Datos institucionales CONAF · nunca al repo público
blcemensual/

# Env files (cada dev configura el suyo)
.env
.env.*
!.env.example

# Secrets / tokens
*.token
*.key
credentials*.json

# OS / Editor
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea
*.pem
*.suo
*.sw?

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Next.js generated
**/next-env.d.ts

# TypeScript build info
*.tsbuildinfo

# Vercel
.vercel
